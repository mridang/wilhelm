{
  "branches": [
    "master",
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "multimod prerelease -m versions.yaml -v v${nextRelease.version}",
        "publishCmd": "find assert env -name go.mod | sed 's|/go.mod$||' | while read d; do git tag \"$d/v${nextRelease.version}\" 2>/dev/null || true; done && git push origin --tags"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "go.mod",
          "go.sum",
          "go.work",
          "go.work.sum",
          "versions.yaml",
          "assert/**/go.mod",
          "assert/**/go.sum",
          "env/**/go.mod",
          "env/**/go.sum"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
